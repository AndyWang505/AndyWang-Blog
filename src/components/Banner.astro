---
import { Image } from 'astro:assets';
import { BANNER_CONFIG } from '../config/banner';

interface Props {
  src?: string;
  alt?: string;
  position?: 'top' | 'center' | 'bottom';
  showCredit?: boolean;
  width?: number;
  height?: number;
}

const { 
  src = BANNER_CONFIG.src, 
  alt = "Blog banner image", 
  position = BANNER_CONFIG.position as 'top' | 'center' | 'bottom',
  showCredit = BANNER_CONFIG.credit.enable,
  width = 1920,
  height = 1080
} = Astro.props;

const imageStyle = `object-position: ${position}`;

const isExternal = src && (src.startsWith('http') || src.startsWith('//'));

let bannerImage;
if (!isExternal && src) {
  try {
    if (src.startsWith('/banner/')) {
      const imagePath = src.replace('/banner/', '');
      bannerImage = await import(`../assets/banner/${imagePath}`);
    }
  } catch (error) {
    console.warn(`Banner image not found in assets: ${src}`);
  }
}
---

{BANNER_CONFIG.enable && (
  <div
    id="banner-wrapper"
    class="absolute z-10 w-full overflow-hidden"
  >
    <div
      id="banner"
      class="w-full h-full relative"
    >
      <!-- Banner 圖片 -->
      {bannerImage ? (
        <Image 
          src={bannerImage.default}
          alt={alt}
          width={width}
          height={height}
          format="webp"
          class="w-full h-full object-cover"
          style={imageStyle}
          loading="eager"
          decoding="async"
          fetchpriority="high"
          quality={85}
        />
      ) : (
        <img 
          src={src}
          alt={alt}
          class="w-full h-full object-cover"
          style={imageStyle}
          loading="eager"
          decoding="async"
          fetchpriority="high"
          width={width}
          height={height}
        />
      )}
      
    </div>
  </div>
)}
