---

<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Weiwei Link</title>
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon" />
    <link rel="shortcut icon" href="/favicon-16x16.png" type="image/png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap"
      rel="stylesheet"
    />

    <!-- Icons -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/fontawesome.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/brands.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/solid.min.css"
    />

    <!-- Preload background -->
    <link
      rel="preload"
      as="image"
      href="https://github.com/AndyWang505/link/blob/main/img/Suisei03.png?raw=true"
    />

    <style>
      /* ── Reset ── */
      html {
        background: #000;
      }

      html,
      body,
      a,
      h1,
      h2,
      h3,
      h4,
      h5,
      h6,
      p,
      span,
      ul,
      ol,
      li {
        margin: 0;
        padding: 0;
        font: inherit;
        font-family: 'Playfair Display', cursive;
        font-weight: 500;
        vertical-align: baseline;
        text-decoration: none;
        list-style: none;
        line-height: 1.5;
        color: rgb(235, 235, 235);
      }

      /* ── Layout ── */
      main {
        position: relative;
        height: 100vh;
        display: flex;
        overflow: hidden;
        justify-content: center;
        align-items: center;
      }

      canvas {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
        opacity: 0;
        transition: opacity 3.5s ease-in-out;
      }

      main.loaded ~ canvas {
        opacity: 1;
      }

      /* ── Background image ── */
      main::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: url(https://github.com/AndyWang505/link/blob/main/img/Suisei03.png?raw=true);
        background-position: center;
        background-size: cover;
        background-attachment: fixed;
        z-index: -1;
        opacity: 0;
        transition: opacity 3.5s ease-in-out;
        animation: bg-scale 60s linear infinite;
      }

      main.loaded::before {
        opacity: 1;
      }

      @keyframes bg-scale {
        from {
          transform: scale(1);
        }
        to {
          transform: scale(1.5);
        }
      }

      /* ── Loader ── */
      #loader-screen {
        position: fixed;
        inset: 0;
        background: transparent;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 99999;
        transition: opacity 0.8s ease;
      }

      #loader-overlay {
        position: absolute;
        inset: 0;
        background: #000;
        z-index: 0;
      }

      #loader-screen.done {
        opacity: 0;
        pointer-events: none;
      }

      #loader-percent {
        font-family: 'Playfair Display', cursive;
        font-size: 3.5rem;
        font-style: italic;
        color: rgba(255, 255, 255, 0.92);
        letter-spacing: -0.02em;
        line-height: 1;
      }

      #loader-suffix {
        font-family: 'Playfair Display', cursive;
        font-size: 1.8rem;
        font-style: italic;
        color: rgba(255, 255, 255, 0.5);
        line-height: 1;
        margin-left: 2px;
      }

      @keyframes num-tick {
        from {
          opacity: 0.2;
          transform: translateY(6px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      #loader-percent.ticking {
        animation: num-tick 0.12s ease-out forwards;
      }

      #loader-bar {
        position: fixed;
        top: 0;
        left: 0;
        height: 3px;
        width: 0%;
        background: linear-gradient(
          90deg,
          rgba(255, 255, 255, 0.4),
          #fff,
          rgba(255, 255, 255, 0.4)
        );
        box-shadow: 0 0 10px rgba(255, 255, 255, 0.6);
        z-index: 9999;
        transition:
          width 0.3s ease,
          opacity 0.5s ease;
      }

      #loader-bar.done {
        opacity: 0;
      }

      /* ── Loader enhancements ── */
      #loader-screen {
        overflow: hidden;
      }

      /* CRT scanline texture */
      #loader-screen::after {
        content: '';
        position: absolute;
        inset: 0;
        background: repeating-linear-gradient(
          0deg,
          transparent,
          transparent 3px,
          rgba(0, 0, 0, 0.07) 3px,
          rgba(0, 0, 0, 0.07) 4px
        );
        pointer-events: none;
        z-index: 0;
      }

      /* Moving scan beam */
      #loader-scan-line {
        position: absolute;
        left: 0;
        right: 0;
        height: 110px;
        background: linear-gradient(
          to bottom,
          transparent,
          rgba(255, 255, 255, 0.045),
          transparent
        );
        animation: scan-move 3.5s linear infinite;
        pointer-events: none;
        z-index: 1;
      }

      @keyframes scan-move {
        from {
          top: -110px;
        }
        to {
          top: 100%;
        }
      }

      /* HUD corner brackets */
      .loader-corner {
        position: absolute;
        width: 28px;
        height: 28px;
        opacity: 0;
        animation: lc-appear 0.5s ease forwards;
        z-index: 2;
      }

      .lc-tl {
        top: 22px;
        left: 22px;
        border-top: 1.5px solid rgba(255, 255, 255, 0.5);
        border-left: 1.5px solid rgba(255, 255, 255, 0.5);
        animation-delay: 0.05s;
      }
      .lc-tr {
        top: 22px;
        right: 22px;
        border-top: 1.5px solid rgba(255, 255, 255, 0.5);
        border-right: 1.5px solid rgba(255, 255, 255, 0.5);
        animation-delay: 0.15s;
      }
      .lc-bl {
        bottom: 22px;
        left: 22px;
        border-bottom: 1.5px solid rgba(255, 255, 255, 0.5);
        border-left: 1.5px solid rgba(255, 255, 255, 0.5);
        animation-delay: 0.25s;
      }
      .lc-br {
        bottom: 22px;
        right: 22px;
        border-bottom: 1.5px solid rgba(255, 255, 255, 0.5);
        border-right: 1.5px solid rgba(255, 255, 255, 0.5);
        animation-delay: 0.35s;
      }

      @keyframes lc-appear {
        from {
          opacity: 0;
          transform: scale(0.3);
        }
        to {
          opacity: 0.65;
          transform: scale(1);
        }
      }

      /* Loader content */
      #loader-content {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      /* Label */
      #loader-label {
        margin-top: 0.3rem;
        font-size: 0.72rem;
        opacity: 0.55;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        transition: opacity 0.25s ease;
      }

      /* Bouncing dots */
      #loader-dots-line {
        display: flex;
        justify-content: center;
        gap: 5px;
        margin-top: 0.2rem;
      }

      .ld {
        opacity: 0;
        font-size: 1rem;
        color: rgba(255, 255, 255, 0.5);
        animation: ld-bounce 1.2s ease-in-out infinite;
      }

      .ld:nth-child(1) {
        animation-delay: 0s;
      }
      .ld:nth-child(2) {
        animation-delay: 0.2s;
      }
      .ld:nth-child(3) {
        animation-delay: 0.4s;
      }

      @keyframes ld-bounce {
        0%,
        100% {
          opacity: 0;
          transform: translateY(0);
        }
        50% {
          opacity: 0.7;
          transform: translateY(-4px);
        }
      }

      /* ── Circular progress ring ── */
      #loader-ring-wrap {
        display: grid;
        width: 220px;
        height: 220px;
        place-items: center;
      }

      #loader-ring-svg {
        grid-area: 1 / 1;
        width: 220px;
        height: 220px;
        transform: rotate(-90deg);
        overflow: visible;
      }

      #loader-ring-bg {
        fill: none;
        stroke: rgba(255, 255, 255, 0.07);
        stroke-width: 1.5;
      }

      #loader-ring-track {
        fill: none;
        stroke: rgba(255, 255, 255, 0.4);
        stroke-width: 1.5;
        stroke-linecap: round;
        stroke-dasharray: 596.9;
        stroke-dashoffset: 596.9;
        transition:
          stroke-dashoffset 0.15s ease,
          filter 0.5s ease,
          stroke 0.3s ease;
      }

      #loader-number-inner {
        grid-area: 1 / 1;
        width: 220px;
        height: 220px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      /* Glow transition on the number */
      #loader-percent {
        transition: text-shadow 0.5s ease;
      }

      #loader-percent,
      #loader-suffix {
        font-variant-numeric: tabular-nums;
      }

      /* ── Card ── */
      section {
        position: absolute;
        padding: 2.8rem 3rem;
        margin: 0 0.3rem;
        min-width: 340px;
        max-width: 420px;
        width: 100%;
        backdrop-filter: blur(10px);
        border: 1.5px solid rgb(230, 230, 230);
        border-radius: 10px;
        z-index: 100;
        opacity: 0;
        transition: opacity 1.5s ease-in-out;
      }

      main.loaded section {
        opacity: 1;
        transition-delay: 1.2s;
        animation: float 6s ease-in-out infinite;
        animation-delay: 3s;
      }

      @keyframes float {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-7px);
        }
      }

      /* ── Status badge ── */
      .status-badge {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.35rem;
        width: fit-content;
        margin: 0 auto 1.6rem;
        padding: 0.18rem 0.65rem;
        border-radius: 9999px;
        border: 1px solid rgba(74, 222, 128, 0.4);
        background: rgba(74, 222, 128, 0.08);
        font-size: 0.7em;
        color: rgb(187, 247, 208);
        letter-spacing: 0.03em;
      }

      .status-dot {
        width: 6px;
        height: 6px;
        border-radius: 9999px;
        background: rgb(74, 222, 128);
        box-shadow: 0 0 5px rgba(74, 222, 128, 0.8);
        flex-shrink: 0;
        animation: dot-pulse 2s ease-in-out infinite;
      }

      @keyframes dot-pulse {
        0%,
        100% {
          opacity: 1;
          transform: scale(1);
        }
        50% {
          opacity: 0.5;
          transform: scale(0.8);
        }
      }

      /* ── Profile ── */
      header {
        text-align: center;
      }

      header p,
      h1 {
        font-style: italic;
      }

      .avatar-wrap {
        position: relative;
        display: inline-block;
        margin-bottom: 0.4rem;
      }

      .avatar-wrap::after {
        content: '';
        position: absolute;
        inset: -3px;
        border-radius: 9999px;
        border: 2px solid rgba(255, 255, 255, 0.55);
        animation: pulse-ring 3s ease-out infinite;
      }

      @keyframes pulse-ring {
        0% {
          transform: scale(1);
          opacity: 0.6;
        }
        100% {
          transform: scale(1.4);
          opacity: 0;
        }
      }

      header img {
        display: block;
        border-radius: 9999px;
        width: 6rem;
        height: 6rem;
        box-shadow:
          0 0 0 2px rgba(255, 255, 255, 0.25),
          0 0 18px rgba(255, 255, 255, 0.12);
        transition: box-shadow 0.3s ease;
      }

      header img:hover {
        box-shadow:
          0 0 0 3px rgba(255, 255, 255, 0.6),
          0 0 28px rgba(255, 255, 255, 0.28);
      }

      header h1 {
        font-size: 1.5em;
        margin: 4px auto;
      }

      .address {
        margin-bottom: 6px;
      }

      .address i {
        margin-right: 0.6rem;
      }

      /* ── Divider ── */
      .divider {
        border: none;
        border-top: 1px solid rgba(255, 255, 255, 0.18);
        margin: 0.8rem 0 0;
      }

      /* ── Links ── */
      li {
        margin: 0.6rem auto;
        opacity: 0;
        transform: translateY(16px);
      }

      main.loaded li {
        animation: slideInUp 0.5s ease forwards;
      }
      main.loaded li:nth-child(1) {
        animation-delay: 1.5s;
      }
      main.loaded li:nth-child(2) {
        animation-delay: 1.62s;
      }
      main.loaded li:nth-child(3) {
        animation-delay: 1.74s;
      }
      main.loaded li:nth-child(4) {
        animation-delay: 1.86s;
      }
      main.loaded li:nth-child(5) {
        animation-delay: 1.98s;
      }

      @keyframes slideInUp {
        to {
          opacity: 1;
          transform: none;
        }
      }

      li a {
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0.3rem 1.2rem;
        border-radius: 8px;
        transition:
          background 0.3s ease,
          box-shadow 0.3s ease;
      }

      /* Shimmer sweep */
      li a::before {
        content: '';
        position: absolute;
        top: 0;
        left: -80%;
        width: 60%;
        height: 100%;
        background: linear-gradient(
          120deg,
          transparent 0%,
          rgba(255, 255, 255, 0.13) 50%,
          transparent 100%
        );
        transition: left 0s;
        pointer-events: none;
      }

      li a:hover::before {
        left: 150%;
        transition: left 0.5s ease;
      }

      li a:hover {
        background: rgba(255, 255, 255, 0.07);
        box-shadow: 0 0 18px rgba(255, 255, 255, 0.1);
      }

      li h2 {
        padding: 0 0.6rem;
        transition: text-shadow 0.3s ease;
      }

      li i {
        font-size: 26px;
        transition: text-shadow 0.3s ease;
      }

      a:hover h2 {
        text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
      }

      a:hover i {
        text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
      }

      /* ── Footer ── */
      footer {
        text-align: center;
        font-size: 0.75em;
        opacity: 0.45;
        margin-top: 0.6rem;
      }

      /* ── Responsive ── */
      @media (max-width: 480px) {
        section {
          padding: 1.8rem 1.6rem;
          min-width: unset;
          max-width: unset;
          width: calc(100vw - 3.6rem);
          border-radius: 14px;
          animation: none !important;
        }

        header img {
          width: 5rem;
          height: 5rem;
        }
        header h1 {
          font-size: 1.3em;
        }
        header p {
          font-size: 13px;
        }
        li {
          margin: 0.45rem auto;
        }
        li i {
          font-size: 22px;
        }
      }

      @media (min-width: 481px) and (max-width: 768px) {
        section {
          max-width: 380px;
          padding: 2.2rem;
        }
      }

      @media (min-width: 769px) {
        section {
          max-width: 520px;
          padding: 3.2rem 3.8rem;
        }
        header img {
          width: 8rem;
          height: 8rem;
        }
        header h1 {
          font-size: 1.9em;
          margin: 8px auto;
        }
        header p {
          font-size: 1.05em;
        }
        .address {
          margin-bottom: 10px;
        }
        li {
          margin: 0.85rem auto;
        }
        li i {
          font-size: 30px;
        }
        li h2 {
          font-size: 1.1em;
        }
      }
    </style>
  </head>
  <body>
    <div id="loader-screen">
      <div id="loader-overlay"></div>
      <div class="loader-corner lc-tl"></div>
      <div class="loader-corner lc-tr"></div>
      <div class="loader-corner lc-bl"></div>
      <div class="loader-corner lc-br"></div>
      <div id="loader-scan-line"></div>
      <div id="loader-content">
        <div id="loader-ring-wrap">
          <svg id="loader-ring-svg" viewBox="0 0 220 220" xmlns="http://www.w3.org/2000/svg">
