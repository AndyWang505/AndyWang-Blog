---
import Layout from '../../layouts/Layout.astro';
---

<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Weiwei Link</title>
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon" />
    <link rel="shortcut icon" href="/favicon-16x16.png" type="image/png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap"
      rel="stylesheet"
    />
    <link rel="preload" as="image" href="https://github.com/AndyWang505/link/blob/main/img/Suisei03.png?raw=true" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/brands.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/solid.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/fontawesome.min.css"
    />

    <style>
      html,
      body,
      a,
      h1,
      h2,
      h3,
      h4,
      h5,
      h6,
      p,
      span,
      ul,
      ol,
      li {
        margin: 0;
        padding: 0;
        font: inherit;
        font-family: 'Playfair Display', cursive;
        font-weight: 500;
        vertical-align: baseline;
        text-decoration: none;
        list-style: none;
        line-height: 1.5;
        color: rgb(235, 235, 235);
      }

      img {
        display: inline-block;
      }

      main {
        position: relative;
        height: 100vh;
        display: flex;
        overflow: hidden;
        justify-content: center;
        align-items: center;
      }

      main::before {
        content: '';
        width: 100%;
        height: 100%;
        position: absolute;
        top: 0;
        left: 0;
        background-image: url(https://github.com/AndyWang505/link/blob/main/img/Suisei03.png?raw=true);
        background-position: center;
        background-size: cover;
        background-attachment: fixed;
        transform: scale(1);
        transition:
          transform 0.2s ease-in-out,
          opacity 1.5s ease-in-out;
        z-index: -1;
        opacity: 0;
      }

      main.loaded::before {
        opacity: 1;
      }

      /* Keyframes animation */
      @keyframes increase {
        0% {
          transform: scale(1);
        }
        100% {
          transform: scale(1.5);
        }
      }

      /* Apply animation to main::before */
      main::before {
        animation: increase 60s linear infinite;
      }

      section {
        position: absolute;
        padding: 2.8rem 3rem;
        margin: 0 0.3rem;
        min-width: 340px;
        backdrop-filter: blur(10px);
        background-color: transparent;
        border: 1.5px solid rgb(230, 230, 230);
        border-radius: 10px;
        z-index: 100;
        opacity: 0;
        transition: opacity 1.5s ease-in-out;
      }

      main.loaded section {
        opacity: 1;
        transition-delay: 1.2s;
        animation: float 6s ease-in-out infinite;
        animation-delay: 3s;
      }

      @keyframes float {
        0%, 100% { transform: translateY(0); }
        50%       { transform: translateY(-7px); }
      }

      header {
        text-align: center;
      }

      .avatar-wrap {
        position: relative;
        display: inline-block;
        margin-bottom: 0.5rem;
      }

      .avatar-wrap::after {
        content: '';
        position: absolute;
        inset: -3px;
        border-radius: 9999px;
        border: 2px solid rgba(255, 255, 255, 0.55);
        animation: pulse-ring 3s ease-out infinite;
      }

      @keyframes pulse-ring {
        0%   { transform: scale(1);   opacity: 0.6; }
        100% { transform: scale(1.4); opacity: 0; }
      }

      header img {
        border-radius: 9999px;
        width: 6rem;
        height: 6rem;
        display: block;
        box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.25), 0 0 18px rgba(255, 255, 255, 0.12);
        transition: box-shadow 0.3s ease;
      }

      header img:hover {
        box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.6), 0 0 28px rgba(255, 255, 255, 0.28);
      }

      header h1 {
        font-size: 1.5em;
        margin: 8px auto;
      }

      .address {
        margin-bottom: 12px;
      }

      .address i {
        margin-right: 0.6rem;
      }

      li {
        margin: 2rem auto;
        opacity: 0;
        transform: translateY(16px);
      }

      main.loaded li {
        animation: slideInUp 0.5s ease forwards;
      }

      main.loaded li:nth-child(1) { animation-delay: 1.5s; }
      main.loaded li:nth-child(2) { animation-delay: 1.62s; }
      main.loaded li:nth-child(3) { animation-delay: 1.74s; }
      main.loaded li:nth-child(4) { animation-delay: 1.86s; }
      main.loaded li:nth-child(5) { animation-delay: 1.98s; }

      @keyframes slideInUp {
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      li a {
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0.3rem 1.2rem;
        border-radius: 8px;
        transition: transform 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
      }

      li a::before {
        content: '';
        position: absolute;
        top: 0;
        left: -80%;
        width: 60%;
        height: 100%;
        background: linear-gradient(
          120deg,
          transparent 0%,
          rgba(255, 255, 255, 0.13) 50%,
          transparent 100%
        );
        transition: left 0s;
        pointer-events: none;
      }

      li a:hover::before {
        left: 150%;
        transition: left 0.5s ease;
      }

      li a:hover {
        transform: scale(1.04);
        background: rgba(255, 255, 255, 0.07);
        box-shadow: 0 0 18px rgba(255, 255, 255, 0.1);
      }

      li h2 {
        padding: 0 0.6rem;
        transition: letter-spacing 0.3s ease, text-shadow 0.3s ease;
      }

      li i {
        font-size: 26px;
        transition: text-shadow 0.3s ease;
      }

      a:hover h2 {
        letter-spacing: 0.06em;
        text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
      }

      a:hover i {
        text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
      }

      .ripple {
        position: absolute;
        border-radius: 9999px;
        background: rgba(255, 255, 255, 0.22);
        transform: scale(0);
        animation: ripple-expand 0.55s ease-out forwards;
        pointer-events: none;
      }

      @keyframes ripple-expand {
        to { transform: scale(2.8); opacity: 0; }
      }

      footer {
        text-align: center;
      }

      canvas {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
      }

      header p,
      h1 {
        font-style: italic;
      }

      /* Mobile responsive */
      @media (max-width: 480px) {
        section {
          padding: 2.2rem 1.4rem;
          min-width: unset;
          width: calc(100vw - 2rem);
        }

        header p {
          font-size: 14px;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <section id="app">
        <header>
          <div class="avatar-wrap">
            <img
              src="https://avatars.githubusercontent.com/u/71600455?v=4"
              alt="head shot"
              fetchpriority="high"
              width="96"
              height="96"
            />
          </div>
          <h1>AndyWang</h1>
          <p class="address">
            <i class="fa-solid fa-location-dot"></i>Taiwan, Hsinchu City
          </p>
          <p>hi, you can call me weiwei. I enjoy solving problems.</p>
        </header>
        <ul>
          <li>
            <a href="https://github.com/AndyWang505" target="_blank">
              <i class="fa-brands fa-github"></i>
              <h2>GitHub</h2>
            </a>
          </li>
          <li>
            <a href="https://andywangtw.dev" target="_blank">
              <i class="fa-solid fa-code"></i>
              <h2>Blog</h2>
            </a>
          </li>
          <li>
            <a href="https://www.pixiv.net/users/39278115" target="_blank">
              <i class="fa-brands fa-pixiv"></i>
              <h2>Pivix</h2>
            </a>
          </li>
          <li>
            <a href="https://x.com/andywang890505" target="_blank">
              <i class="fa-brands fa-twitter"></i>
              <h2>Twitter</h2>
            </a>
          </li>
          <li>
            <a href="mailto:andywang890505@gmail.com" target="_blank">
              <i class="fa-solid fa-envelope"></i>
              <h2>Email</h2>
            </a>
          </li>
        </ul>
        <footer>Copyright © 2024 - AndyWang.</footer>
      </section>
    </main>
    <canvas id="starryCanvas"></canvas>

    <script is:inline lang="ts">
      // Starry background animation
      const canvas = document.getElementById('starryCanvas');
      const ctx = canvas.getContext('2d');

      // Set canvas size
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;

      // Array to store stars
      const stars = [];
      const numStars = 500; // Number of stars

      function createStar() {
        return {
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          size: Math.random() * 1.5 + 0.5, // Size of the star
          speed: Math.random() * 0.2 + 0.1, // Falling speed (slower)
          opacity: Math.random() * 0.5 + 0.5, // Random opacity (between 0.5 and 1)
        };
      }

      // Initialize stars
      for (let i = 0; i < numStars; i++) {
        stars.push(createStar());
      }

      function drawStars() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        stars.forEach((star) => {
          ctx.beginPath();
          ctx.arc(star.x, star.y, star.size, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(255, 255, 255, ${star.opacity})`; // Apply opacity
          ctx.fill();
        });
      }

      function updateStars() {
        stars.forEach((star) => {
          star.y += star.speed; // Move the star downwards
          if (star.y > canvas.height) {
            // Reset the star to the top if it goes off screen
            star.y = 0;
            star.x = Math.random() * canvas.width;
            star.size = Math.random() * 1.5 + 0.5; // Random size
            star.speed = Math.random() * 0.2 + 0.1; // Random speed
            star.opacity = Math.random() * 0.5 + 0.5; // Random opacity
          }
        });
      }

      // Shooting stars
      const shootingStars = [];

      function createShootingStar() {
        return {
          x: Math.random() * canvas.width * 0.7,
          y: Math.random() * canvas.height * 0.4,
          length: Math.random() * 100 + 60,
          speed: Math.random() * 6 + 4,
          opacity: 1,
          angle: Math.PI / 5,
          active: true,
        };
      }

      function drawShootingStars() {
        shootingStars.forEach((s, idx) => {
          if (!s.active) return;
          const dx = Math.cos(s.angle) * s.length;
          const dy = Math.sin(s.angle) * s.length;
          const grad = ctx.createLinearGradient(s.x, s.y, s.x - dx, s.y - dy);
          grad.addColorStop(0, `rgba(255, 255, 255, ${s.opacity})`);
          grad.addColorStop(1, 'rgba(255, 255, 255, 0)');
          ctx.beginPath();
          ctx.moveTo(s.x, s.y);
          ctx.lineTo(s.x - dx, s.y - dy);
          ctx.strokeStyle = grad;
          ctx.lineWidth = 1.5;
          ctx.stroke();
          s.x += Math.cos(s.angle) * s.speed;
          s.y += Math.sin(s.angle) * s.speed;
          s.opacity -= 0.018;
          if (s.opacity <= 0 || s.x > canvas.width || s.y > canvas.height) {
            shootingStars.splice(idx, 1);
          }
        });
      }

      // Spawn a shooting star every 2.5–5 seconds
      function scheduleShootingStar() {
        shootingStars.push(createShootingStar());
        setTimeout(scheduleShootingStar, Math.random() * 2500 + 2500);
      }
      scheduleShootingStar();

      function animate() {
        drawStars();
        drawShootingStars();
        updateStars();
        requestAnimationFrame(animate);
      }

      animate(); // Start the animation

      // Adjust canvas size on window resize (debounced)
      let resizeTimer;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => {
          canvas.width = window.innerWidth;
          canvas.height = window.innerHeight;
        }, 100);
      });

      // Background image fade-in effect with fallback timeout
      const mainElement = document.querySelector('main');
      if (mainElement) {
        const backgroundImage = new Image();
        backgroundImage.src =
          'https://github.com/AndyWang505/link/blob/main/img/Suisei03.png?raw=true';

        const fallback = setTimeout(() => mainElement.classList.add('loaded'), 3000);

        backgroundImage.onload = () => {
          clearTimeout(fallback);
          mainElement.classList.add('loaded');
        };
      }

      // Ripple effect on link click
      document.querySelectorAll('li a').forEach((link) => {
        link.addEventListener('click', function (e) {
          const ripple = document.createElement('span');
          ripple.classList.add('ripple');
          const rect = this.getBoundingClientRect();
          const size = Math.max(rect.width, rect.height);
          ripple.style.width = ripple.style.height = size + 'px';
          ripple.style.left = e.clientX - rect.left - size / 2 + 'px';
          ripple.style.top = e.clientY - rect.top - size / 2 + 'px';
          this.appendChild(ripple);
          ripple.addEventListener('animationend', () => ripple.remove());
        });
      });
    </script>
  </body>
</html>
