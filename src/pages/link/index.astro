    <canvas id="starryCanvas"></canvas>

    <script is:inline>
      // ── Canvas setup ──
      const canvas = document.getElementById('starryCanvas');
      const ctx = canvas.getContext('2d');
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;

      let resizeTimer;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => {
          canvas.width = window.innerWidth;
          canvas.height = window.innerHeight;
        }, 100);
      });

      // ── Stars ──
      const stars = Array.from({ length: 500 }, () => createStar());

      function createStar() {
        return {
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          size: Math.random() * 1.5 + 0.5,
          speed: Math.random() * 0.2 + 0.1,
          opacity: Math.random() * 0.5 + 0.5,
        };
      }

      function drawStars() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        stars.forEach((star) => {
          ctx.beginPath();
          ctx.arc(star.x, star.y, star.size, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(255, 255, 255, ${star.opacity})`;
          ctx.fill();
        });
      }

      function updateStars() {
        stars.forEach((star) => {
          star.y += star.speed;
          if (star.y > canvas.height) {
            star.y = 0;
            star.x = Math.random() * canvas.width;
            star.size = Math.random() * 1.5 + 0.5;
            star.speed = Math.random() * 0.2 + 0.1;
            star.opacity = Math.random() * 0.5 + 0.5;
          }
        });
      }

      // ── Shooting stars ──
      const shootingStars = [];

      function createShootingStar() {
        return {
          x: Math.random() * canvas.width * 0.7,
          y: Math.random() * canvas.height * 0.4,
          length: Math.random() * 100 + 60,
          speed: Math.random() * 6 + 4,
          opacity: 1,
          angle: Math.PI / 5,
        };
      }

      function drawShootingStars() {
        shootingStars.forEach((s, idx) => {
          const dx = Math.cos(s.angle) * s.length;
          const dy = Math.sin(s.angle) * s.length;
          const grad = ctx.createLinearGradient(s.x, s.y, s.x - dx, s.y - dy);
          grad.addColorStop(0, `rgba(255, 255, 255, ${s.opacity})`);
          grad.addColorStop(1, 'rgba(255, 255, 255, 0)');
          ctx.beginPath();
          ctx.moveTo(s.x, s.y);
          ctx.lineTo(s.x - dx, s.y - dy);
          ctx.strokeStyle = grad;
          ctx.lineWidth = 1.5;
          ctx.stroke();
          s.x += Math.cos(s.angle) * s.speed;
          s.y += Math.sin(s.angle) * s.speed;
          s.opacity -= 0.018;
          if (s.opacity <= 0 || s.x > canvas.width || s.y > canvas.height) {
            shootingStars.splice(idx, 1);
          }
        });
      }

      function scheduleShootingStar() {
        shootingStars.push(createShootingStar());
        setTimeout(scheduleShootingStar, Math.random() * 2500 + 2500);
      }
      scheduleShootingStar();

      // ── Animation loop ──
      function animate() {
        drawStars();
        drawShootingStars();
        updateStars();
        requestAnimationFrame(animate);
      }
      animate();

      // ── Loader ──
      const loaderBar = document.getElementById('loader-bar');
      const loaderScreen = document.getElementById('loader-screen');
      const loaderOverlay = document.getElementById('loader-overlay');
      const loaderPercent = document.getElementById('loader-percent');
      const loaderLabel = document.getElementById('loader-label');
      const ringTrack = document.getElementById('loader-ring-track');
      const numberInner = document.getElementById('loader-number-inner');
      const RING_CIRC = 2 * Math.PI * 95; // 596.9
      let loaderProgress = 0;
      let glitchCount = 0;
      const passedMilestones = new Set();

      function tickNumber(value) {
        loaderPercent.classList.remove('ticking');
        void loaderPercent.offsetWidth; // force reflow to restart animation
        loaderPercent.textContent = value;
        loaderPercent.classList.add('ticking');
      }

      // Fade overlay from opaque→transparent as progress 30%→100%
      function updateOverlay(p) {
        const alpha = p <= 30 ? 1 : 1 - (p - 30) / 70;
        loaderOverlay.style.opacity = Math.max(0, alpha).toFixed(3);
      }

      // ── Ring + glow helpers ──
      function updateRing(p) {
        ringTrack.style.strokeDashoffset = RING_CIRC * (1 - p / 100);
        const glow = (p / 100) * 14;
        const opacity = 0.25 + (p / 100) * 0.45;
        ringTrack.style.filter = `drop-shadow(0 0 ${glow.toFixed(1)}px rgba(255,255,255,${opacity.toFixed(2)}))`;
      }

      function updateNumberGlow(p) {
        const g = ((p / 100) * 28).toFixed(0);
        const o = ((p / 100) * 0.6).toFixed(2);
        loaderPercent.style.textShadow = `0 0 ${g}px rgba(255,255,255,${o})`;
      }

      function triggerMilestone(color) {
        ringTrack.style.stroke = color;
        setTimeout(() => {
          ringTrack.style.stroke = '';
        }, 350);
      }

      // ── Cycling messages ──
      const loaderMessages = ['Initializing', 'Loading assets', 'Rendering world', 'Almost there'];
      let msgIdx = 0;
      const msgTimer = setInterval(() => {
        msgIdx = (msgIdx + 1) % loaderMessages.length;
        loaderLabel.style.opacity = '0';
        setTimeout(() => {
          loaderLabel.textContent = loaderMessages[msgIdx];
          loaderLabel.style.opacity = '1';
        }, 250);
      }, 900);

      // ── Progress interval ──
      const loaderInterval = setInterval(() => {
        if (loaderProgress < 30) loaderProgress += 4;
        else if (loaderProgress < 60) loaderProgress += 2;
        else if (loaderProgress < 85) loaderProgress += 0.6;
        else {
          clearInterval(loaderInterval);
          return;
        }

        loaderBar.style.width = loaderProgress + '%';
        updateRing(loaderProgress);
        updateNumberGlow(loaderProgress);
        updateOverlay(loaderProgress);
        triggerPop();

        // Milestone colour pulse: 25 / 50 / 75
        for (const [threshold, color] of [
          [25, 'rgba(180,230,255,0.9)'],
          [50, 'rgba(200,180,255,0.9)'],
          [75, 'rgba(255,220,160,0.9)'],
        ]) {
          if (loaderProgress >= threshold && !passedMilestones.has(threshold)) {
            passedMilestones.add(threshold);
            triggerMilestone(color);
          }
        }

        // Occasional glitch: flash wrong digit then snap back
        glitchCount++;
        if (glitchCount % 9 === 0) {
          const correct = Math.floor(loaderProgress);
          tickNumber(Math.floor(Math.random() * 10));
          loaderPercent.classList.add('glitching');
          setTimeout(() => {
            tickNumber(correct);
            loaderPercent.classList.remove('glitching');
          }, 90);
        } else {
          tickNumber(Math.floor(loaderProgress));
        }
      }, 120);

      function completeLoader() {
        clearInterval(loaderInterval);
        clearInterval(msgTimer);
        loaderBar.style.width = '100%';
        tickNumber('100');
        loaderPercent.classList.remove('glitching');
        loaderLabel.style.opacity = '1';
        loaderLabel.textContent = 'Complete';
        updateRing(100);
        updateNumberGlow(100);

        setTimeout(() => {
          loaderScreen.classList.add('done');
          loaderBar.classList.add('done');
        }, 500);
      }

      // ── Background image & page reveal ──
      const mainElement = document.querySelector('main');
      const backgroundImage = new Image();
      backgroundImage.src =
        'https://github.com/AndyWang505/link/blob/main/img/Suisei03.png?raw=true';

      const fallback = setTimeout(() => {
        mainElement.classList.add('loaded');
        completeLoader();
      }, 3000);

      backgroundImage.onload = () => {
        clearTimeout(fallback);
        mainElement.classList.add('loaded');
        completeLoader();
      };

    </script>
  </body>
</html>
