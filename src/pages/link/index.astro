---
---

<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Weiwei Link</title>
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon" />
    <link rel="shortcut icon" href="/favicon-16x16.png" type="image/png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap"
      rel="stylesheet"
    />

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/fontawesome.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/brands.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/solid.min.css" />

    <!-- Preload background -->
    <link rel="preload" as="image" href="https://github.com/AndyWang505/link/blob/main/img/Suisei03.png?raw=true" />

    <style>
      /* ── Reset ── */
      html, body, a, h1, h2, h3, h4, h5, h6, p, span, ul, ol, li {
        margin: 0;
        padding: 0;
        font: inherit;
        font-family: 'Playfair Display', cursive;
        font-weight: 500;
        vertical-align: baseline;
        text-decoration: none;
        list-style: none;
        line-height: 1.5;
        color: rgb(235, 235, 235);
      }

      /* ── Layout ── */
      main {
        position: relative;
        height: 100vh;
        display: flex;
        overflow: hidden;
        justify-content: center;
        align-items: center;
      }

      canvas {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
      }

      /* ── Background image ── */
      main::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: url(https://github.com/AndyWang505/link/blob/main/img/Suisei03.png?raw=true);
        background-position: center;
        background-size: cover;
        background-attachment: fixed;
        z-index: -1;
        opacity: 0;
        transition: opacity 1.5s ease-in-out;
        animation: bg-scale 60s linear infinite;
      }

      main.loaded::before {
        opacity: 1;
      }

      @keyframes bg-scale {
        from { transform: scale(1); }
        to   { transform: scale(1.5); }
      }

      /* ── Loader ── */
      #loader-screen {
        position: fixed;
        inset: 0;
        background: #000;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 99999;
        transition: opacity 0.7s ease;
      }

      #loader-screen.done {
        opacity: 0;
        pointer-events: none;
      }

      #loader-percent {
        font-family: 'Playfair Display', cursive;
        font-size: 6rem;
        font-style: italic;
        color: rgba(255, 255, 255, 0.88);
        letter-spacing: -0.02em;
        line-height: 1;
      }

      #loader-bar {
        position: fixed;
        top: 0;
        left: 0;
        height: 3px;
        width: 0%;
        background: linear-gradient(90deg, rgba(255,255,255,0.4), #fff, rgba(255,255,255,0.4));
        box-shadow: 0 0 10px rgba(255, 255, 255, 0.6);
        z-index: 9999;
        transition: width 0.3s ease, opacity 0.5s ease;
      }

      #loader-bar.done {
        opacity: 0;
      }

      /* ── Card ── */
      section {
        position: absolute;
        padding: 2.8rem 3rem;
        margin: 0 0.3rem;
        min-width: 340px;
        max-width: 420px;
        width: 100%;
        backdrop-filter: blur(10px);
        border: 1.5px solid rgb(230, 230, 230);
        border-radius: 10px;
        z-index: 100;
        opacity: 0;
        transition: opacity 1.5s ease-in-out;
      }

      main.loaded section {
        opacity: 1;
        transition-delay: 1.2s;
        animation: float 6s ease-in-out infinite;
        animation-delay: 3s;
      }

      @keyframes float {
        0%, 100% { transform: translateY(0); }
        50%       { transform: translateY(-7px); }
      }

      /* ── Status badge ── */
      .status-badge {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.35rem;
        width: fit-content;
        margin: 0 auto 1.6rem;
        padding: 0.18rem 0.65rem;
        border-radius: 9999px;
        border: 1px solid rgba(74, 222, 128, 0.4);
        background: rgba(74, 222, 128, 0.08);
        font-size: 0.7em;
        color: rgb(187, 247, 208);
        letter-spacing: 0.03em;
      }

      .status-dot {
        width: 6px;
        height: 6px;
        border-radius: 9999px;
        background: rgb(74, 222, 128);
        box-shadow: 0 0 5px rgba(74, 222, 128, 0.8);
        flex-shrink: 0;
        animation: dot-pulse 2s ease-in-out infinite;
      }

      @keyframes dot-pulse {
        0%, 100% { opacity: 1;   transform: scale(1); }
        50%       { opacity: 0.5; transform: scale(0.8); }
      }

      /* ── Profile ── */
      header {
        text-align: center;
      }

      header p, h1 {
        font-style: italic;
      }

      .avatar-wrap {
        position: relative;
        display: inline-block;
        margin-bottom: 0.4rem;
      }

      .avatar-wrap::after {
        content: '';
        position: absolute;
        inset: -3px;
        border-radius: 9999px;
        border: 2px solid rgba(255, 255, 255, 0.55);
        animation: pulse-ring 3s ease-out infinite;
      }

      @keyframes pulse-ring {
        0%   { transform: scale(1);   opacity: 0.6; }
        100% { transform: scale(1.4); opacity: 0; }
      }

      header img {
        display: block;
        border-radius: 9999px;
        width: 6rem;
        height: 6rem;
        box-shadow: 0 0 0 2px rgba(255,255,255,0.25), 0 0 18px rgba(255,255,255,0.12);
        transition: box-shadow 0.3s ease;
      }

      header img:hover {
        box-shadow: 0 0 0 3px rgba(255,255,255,0.6), 0 0 28px rgba(255,255,255,0.28);
      }

      header h1 {
        font-size: 1.5em;
        margin: 4px auto;
      }

      .address {
        margin-bottom: 6px;
      }

      .address i {
        margin-right: 0.6rem;
      }

      /* ── Divider ── */
      .divider {
        border: none;
        border-top: 1px solid rgba(255, 255, 255, 0.18);
        margin: 0.8rem 0 0;
      }

      /* ── Links ── */
      li {
        margin: 0.6rem auto;
        opacity: 0;
        transform: translateY(16px);
      }

      main.loaded li { animation: slideInUp 0.5s ease forwards; }
      main.loaded li:nth-child(1) { animation-delay: 1.5s; }
      main.loaded li:nth-child(2) { animation-delay: 1.62s; }
      main.loaded li:nth-child(3) { animation-delay: 1.74s; }
      main.loaded li:nth-child(4) { animation-delay: 1.86s; }
      main.loaded li:nth-child(5) { animation-delay: 1.98s; }

      @keyframes slideInUp {
        to { opacity: 1; transform: translateY(0); }
      }

      li a {
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0.3rem 1.2rem;
        border-radius: 8px;
        transition: transform 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
      }

      /* Shimmer sweep */
      li a::before {
        content: '';
        position: absolute;
        top: 0;
        left: -80%;
        width: 60%;
        height: 100%;
        background: linear-gradient(120deg, transparent 0%, rgba(255,255,255,0.13) 50%, transparent 100%);
        transition: left 0s;
        pointer-events: none;
      }

      li a:hover::before {
        left: 150%;
        transition: left 0.5s ease;
      }

      li a:hover {
        transform: scale(1.04);
        background: rgba(255, 255, 255, 0.07);
        box-shadow: 0 0 18px rgba(255, 255, 255, 0.1);
      }

      li h2 {
        padding: 0 0.6rem;
        transition: letter-spacing 0.3s ease, text-shadow 0.3s ease;
      }

      li i {
        font-size: 26px;
        transition: text-shadow 0.3s ease;
      }

      a:hover h2 {
        letter-spacing: 0.06em;
        text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
      }

      a:hover i {
        text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
      }

      /* Ripple */
      .ripple {
        position: absolute;
        border-radius: 9999px;
        background: rgba(255, 255, 255, 0.22);
        transform: scale(0);
        animation: ripple-expand 0.55s ease-out forwards;
        pointer-events: none;
      }

      @keyframes ripple-expand {
        to { transform: scale(2.8); opacity: 0; }
      }

      /* ── Footer ── */
      footer {
        text-align: center;
        font-size: 0.75em;
        opacity: 0.45;
        margin-top: 0.6rem;
      }

      /* ── Responsive ── */
      @media (max-width: 480px) {
        section {
          padding: 1.8rem 1.6rem;
          min-width: unset;
          max-width: unset;
          width: calc(100vw - 3.6rem);
          border-radius: 14px;
          animation: none !important;
        }

        header img { width: 5rem; height: 5rem; }
        header h1  { font-size: 1.3em; }
        header p   { font-size: 13px; }
        li         { margin: 0.45rem auto; }
        li i       { font-size: 22px; }
      }

      @media (min-width: 481px) and (max-width: 768px) {
        section {
          max-width: 380px;
          padding: 2.2rem;
        }
      }

      @media (min-width: 769px) {
        section     { max-width: 520px; padding: 3.2rem 3.8rem; }
        header img  { width: 8rem; height: 8rem; }
        header h1   { font-size: 1.9em; margin: 8px auto; }
        header p    { font-size: 1.05em; }
        .address    { margin-bottom: 10px; }
        li          { margin: 0.85rem auto; }
        li i        { font-size: 30px; }
        li h2       { font-size: 1.1em; }
      }
    </style>
  </head>
  <body>
    <div id="loader-screen">
      <div id="loader-content">
        <span id="loader-percent">0</span><span id="loader-suffix">%</span>
        <p id="loader-label">Loading</p>
      </div>
    </div>
    <div id="loader-bar"></div>

    <main>
      <section id="app">
        <div class="status-badge">
          <span class="status-dot"></span>
          Open to work
        </div>
        <header>
          <div class="avatar-wrap">
            <img
              src="https://avatars.githubusercontent.com/u/71600455?v=4"
              alt="head shot"
              fetchpriority="high"
              width="96"
              height="96"
            />
          </div>
          <h1>AndyWang</h1>
          <p class="address">
            <i class="fa-solid fa-location-dot"></i>Taiwan, Hsinchu City
          </p>
          <p>hi, you can call me weiwei. I enjoy solving problems.</p>
        </header>
        <hr class="divider" />
        <ul>
          <li>
            <a href="https://github.com/AndyWang505" target="_blank">
              <i class="fa-brands fa-github"></i>
              <h2>GitHub</h2>
            </a>
          </li>
          <li>
            <a href="https://andywangtw.dev" target="_blank">
              <i class="fa-solid fa-code"></i>
              <h2>Blog</h2>
            </a>
          </li>
          <li>
            <a href="https://www.pixiv.net/users/39278115" target="_blank">
              <i class="fa-brands fa-pixiv"></i>
              <h2>Pivix</h2>
            </a>
          </li>
          <li>
            <a href="https://x.com/andywang890505" target="_blank">
              <i class="fa-brands fa-twitter"></i>
              <h2>Twitter</h2>
            </a>
          </li>
          <li>
            <a href="mailto:andywang890505@gmail.com" target="_blank">
              <i class="fa-solid fa-envelope"></i>
              <h2>Email</h2>
            </a>
          </li>
        </ul>
        <footer>Copyright © 2024 - AndyWang.</footer>
      </section>
    </main>

    <canvas id="starryCanvas"></canvas>

    <script is:inline>
      // ── Canvas setup ──
      const canvas = document.getElementById('starryCanvas');
      const ctx = canvas.getContext('2d');
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;

      let resizeTimer;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => {
          canvas.width = window.innerWidth;
          canvas.height = window.innerHeight;
        }, 100);
      });

      // ── Stars ──
      const stars = Array.from({ length: 500 }, () => createStar());

      function createStar() {
        return {
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          size: Math.random() * 1.5 + 0.5,
          speed: Math.random() * 0.2 + 0.1,
          opacity: Math.random() * 0.5 + 0.5,
        };
      }

      function drawStars() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        stars.forEach((star) => {
          ctx.beginPath();
          ctx.arc(star.x, star.y, star.size, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(255, 255, 255, ${star.opacity})`;
          ctx.fill();
        });
      }

      function updateStars() {
        stars.forEach((star) => {
          star.y += star.speed;
          if (star.y > canvas.height) {
            star.y = 0;
            star.x = Math.random() * canvas.width;
            star.size = Math.random() * 1.5 + 0.5;
            star.speed = Math.random() * 0.2 + 0.1;
            star.opacity = Math.random() * 0.5 + 0.5;
          }
        });
      }

      // ── Shooting stars ──
      const shootingStars = [];

      function createShootingStar() {
        return {
          x: Math.random() * canvas.width * 0.7,
          y: Math.random() * canvas.height * 0.4,
          length: Math.random() * 100 + 60,
          speed: Math.random() * 6 + 4,
          opacity: 1,
          angle: Math.PI / 5,
        };
      }

      function drawShootingStars() {
        shootingStars.forEach((s, idx) => {
          const dx = Math.cos(s.angle) * s.length;
          const dy = Math.sin(s.angle) * s.length;
          const grad = ctx.createLinearGradient(s.x, s.y, s.x - dx, s.y - dy);
          grad.addColorStop(0, `rgba(255, 255, 255, ${s.opacity})`);
          grad.addColorStop(1, 'rgba(255, 255, 255, 0)');
          ctx.beginPath();
          ctx.moveTo(s.x, s.y);
          ctx.lineTo(s.x - dx, s.y - dy);
          ctx.strokeStyle = grad;
          ctx.lineWidth = 1.5;
          ctx.stroke();
          s.x += Math.cos(s.angle) * s.speed;
          s.y += Math.sin(s.angle) * s.speed;
          s.opacity -= 0.018;
          if (s.opacity <= 0 || s.x > canvas.width || s.y > canvas.height) {
            shootingStars.splice(idx, 1);
          }
        });
      }

      function scheduleShootingStar() {
        shootingStars.push(createShootingStar());
        setTimeout(scheduleShootingStar, Math.random() * 2500 + 2500);
      }
      scheduleShootingStar();

      // ── Animation loop ──
      function animate() {
        drawStars();
        drawShootingStars();
        updateStars();
        requestAnimationFrame(animate);
      }
      animate();

      // ── Loader ──
      const loaderBar = document.getElementById('loader-bar');
      const loaderScreen = document.getElementById('loader-screen');
      const loaderPercent = document.getElementById('loader-percent');
      let loaderProgress = 0;

      const loaderInterval = setInterval(() => {
        if      (loaderProgress < 30) loaderProgress += 4;
        else if (loaderProgress < 60) loaderProgress += 2;
        else if (loaderProgress < 85) loaderProgress += 0.6;
        else { clearInterval(loaderInterval); return; }
        loaderBar.style.width = loaderProgress + '%';
        loaderPercent.textContent = Math.floor(loaderProgress);
      }, 120);

      function completeLoader() {
        clearInterval(loaderInterval);
        loaderBar.style.width = '100%';
        loaderPercent.textContent = '100';
        setTimeout(() => {
          loaderScreen.classList.add('done');
          loaderBar.classList.add('done');
        }, 400);
      }

      // ── Background image & page reveal ──
      const mainElement = document.querySelector('main');
      const backgroundImage = new Image();
      backgroundImage.src = 'https://github.com/AndyWang505/link/blob/main/img/Suisei03.png?raw=true';

      const fallback = setTimeout(() => {
        mainElement.classList.add('loaded');
        completeLoader();
      }, 3000);

      backgroundImage.onload = () => {
        clearTimeout(fallback);
        mainElement.classList.add('loaded');
        completeLoader();
      };

      // ── Ripple on link click ──
      document.querySelectorAll('li a').forEach((link) => {
        link.addEventListener('click', function (e) {
          const ripple = document.createElement('span');
          ripple.classList.add('ripple');
          const rect = this.getBoundingClientRect();
          const size = Math.max(rect.width, rect.height);
          ripple.style.width = ripple.style.height = size + 'px';
          ripple.style.left = e.clientX - rect.left - size / 2 + 'px';
          ripple.style.top = e.clientY - rect.top - size / 2 + 'px';
          this.appendChild(ripple);
          ripple.addEventListener('animationend', () => ripple.remove());
        });
      });
    </script>
  </body>
</html>
